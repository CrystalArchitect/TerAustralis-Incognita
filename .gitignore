# Secrets — never commit
.env
.envrc
*.pem
*.key
credentials*
auth.json

# Python
__pycache__/
*.pyc
.venv/
venv/

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp

# Generated corpus is build output (see AGENTS.md: do not hand-edit)
corpus/

# Clementine local memory — personal conversations and profiles never go in git
clementine_memory.json
clementine_memory/
clementine_profiles/
memory/config.json

# CrystalCore.OS local state — user preferences, progress, active learning queue
.crystalcore/

# CrystalBridge audit trail and guest messages — real conversation content,
# never go in git (bridge_config.json itself is fine to commit)
src/profiles/*/audit.jsonl
src/profiles/*/messages.jsonl

# Starline identity/peers/consent — this device's private key and address
# book, never go in git, wherever an agent happens to run from
starline_identity.json
starline_peers.json
starline_consent.json
**/starline_identity.json
**/starline_peers.json
**/starline_consent.json

# Node / site build output — .svelte-kit is generated by the dev server;
# never commit it (phantom-diff magnet for collaborators)
node_modules/
src/site/build/
.svelte-kit/
dist/
